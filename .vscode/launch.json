    "version": "0.2.0",
    "configurations": [
        {
            "name": "build and debug project",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Code/parser-gdb",
            "args": [
                "../Test/impossible1.cmm"
            ],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}/Code",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build project",
            "miDebuggerPath": "/usr/bin/gdb"
        }
    ]
}